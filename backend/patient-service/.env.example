PORT=3004
MONGO_URI=mongodb://localhost:27017/healthcare-platform
JWT_SECRET=change-me-secret

# AWS S3 — medical report uploads (patient-service)
AWS_S3_ACCESS_KEY_ID=
AWS_S3_SECRET_ACCESS_KEY=
AWS_S3_REGION=us-east-1
AWS_S3_BUCKET_NAME=
# Optional: custom public base (e.g. CloudFront). Default: https://{bucket}.s3.{region}.amazonaws.com
# AWS_S3_PUBLIC_URL_BASE=

# Public URL of this API (used in fileUrl when storing uploads locally under ./uploads).
# Docker / deploy: MUST match what browsers use (same scheme+host+port as exposed patient API).
# Also used to rewrite old DB rows that still point at http://localhost:.../uploads/...
# PATIENT_API_PUBLIC_URL=http://localhost:3004
