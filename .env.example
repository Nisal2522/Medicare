# Copy to .env in this folder (repo root). Used by Docker Compose variable substitution.
# Do not commit real secrets.
#
# IMPORTANT: Run Docker Compose from this folder (repo root):  docker compose up --build
# If you run compose from infrastructure/docker without --project-directory, MONGO_URI_* may be empty
# and services fall back to the local mongodb container — data will not appear in Atlas.
#
# MongoDB Atlas (no quotes on the URL lines):
# MONGO_URI_AUTH=mongodb+srv://USER:PASS@cluster.mongodb.net/medicare-auth?appName=...
# MONGO_URI_DOCTOR=mongodb+srv://...
# MONGO_URI_APPOINTMENT=mongodb+srv://...
# MONGO_URI_PATIENT=mongodb+srv://...
# MONGO_URI_TELEMEDICINE=mongodb+srv://...
# Atlas → Network Access: allow your IP or 0.0.0.0/0 for dev. Omit these lines to use the local mongodb container.

JWT_SECRET=change-me-secret
INTERNAL_SERVICE_KEY=dev-internal-key

# CORS — comma-separated list of allowed origins (applied to all backend services).
# Leave empty to allow all origins (dev only). In production, set to your frontend URL.
# CORS_ORIGINS=https://your-app.vercel.app

# Optional — payment-service (Stripe test)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# Optional — notification-service
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Optional — ai-service (Groq; use backend/ai-service/.env for local/Docker)
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama3-8b-8192
